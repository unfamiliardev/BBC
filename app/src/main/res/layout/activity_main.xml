<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="horizontal">

    <!-- ── Sidebar ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:background="@color/sidebar_bg"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginBottom="28dp"
            android:contentDescription="@null" />

        <ImageButton
            android:id="@+id/nav_recent"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/sidebar_item_bg"
            android:src="@drawable/ic_nav_recent"
            android:scaleType="center"
            android:contentDescription="Recent"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/nav_channels"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/sidebar_item_bg"
            android:src="@drawable/ic_nav_channels"
            android:scaleType="center"
            android:contentDescription="Channels"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/nav_epg"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/sidebar_item_bg"
            android:src="@drawable/ic_nav_epg"
            android:scaleType="center"
            android:contentDescription="TV Guide"
            android:focusable="true" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/nav_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/sidebar_item_bg"
            android:src="@drawable/ic_nav_settings"
            android:scaleType="center"
            android:contentDescription="Settings"
            android:focusable="true" />

    </LinearLayout>

    <!-- ── Content ─────────────────────────────── -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />

    <!-- ── Preview panel ───────────────────────── -->
    <LinearLayout
        android:id="@+id/preview_panel"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:background="@color/preview_bg"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/preview_logo"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/preview_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            android:hint="Select a channel"
            android:textColorHint="@color/secondary_text" />

        <TextView
            android:id="@+id/preview_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/secondary_text"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/preview_now_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/now_playing"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/preview_now_playing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/primary_text"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/preview_fav_btn"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/item_focused_bg"
            android:textColor="@color/primary_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:focusable="true"
            android:text="@string/fav_add"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/preview_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/press_ok"
            android:textColor="@color/secondary_text"
            android:textSize="11sp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
